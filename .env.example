# Copy to .env and fill in your values

# LLM provider and model
PROVIDER=openai
MODEL_NAME=gpt-4o-mini
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Agent behaviour
AGENT_MAX_ITERATIONS=20
AGENT_MAX_TOKENS=8192
AGENT_SYSTEM_PROMPT="You are a helpful AI assistant for Amlogic R&D automation."

# File sandbox root (defaults to cwd)
# WORK_DIR=

# Skills directory (defaults to WORK_DIR/skills and ~/.aiyo/skills)
# SKILLS_DIR=

# Enable unified exceptions across all LLM providers
ANY_LLM_UNIFIED_EXCEPTIONS=1

# --- Atlassian tool credentials ---

# Jira
# JIRA_SERVER=https://jira.example.com
# JIRA_USERNAME=
# JIRA_PASSWORD=

# Confluence
# CONFLUENCE_SERVER=https://confluence.example.com
# CONFLUENCE_TOKEN=          # PAT (preferred)
# CONFLUENCE_USERNAME=       # fallback basic auth
# CONFLUENCE_PASSWORD=

# Gerrit
# GERRIT_SERVER=https://gerrit.example.com
# GERRIT_USERNAME=
# GERRIT_PASSWORD=
